// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String   @id @default(uuid())
  username            String   @unique
  email               String   @unique
  avatarUrl           String?
  totalSnippets       Int      @default(0)
  totalPublicSnippets Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  snippets    Snippet[]
  collections Collection[]
  likes       Like[]
}

model Snippet {
  id           String   @id @default(uuid())
  userId       String
  title        String
  description  String?
  code         String   @db.Text
  language     String
  isPublic     Boolean  @default(false)
  collectionId String?
  likes        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id])
  collection Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  snippetTags SnippetTag[]   // mudou
  likesList   Like[]
}


model Collection {
  id             String   @id @default(uuid())
  userId         String
  name           String
  description    String?
  isPublic       Boolean  @default(false)
  snippetCount   Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  snippets Snippet[]



  @@index([userId])
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  category  String
  createdAt DateTime @default(now())

  snippetTags SnippetTag[]
}


model Like {
  id        String   @id @default(uuid())
  userId    String
  snippetId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  snippet Snippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)

  @@unique([userId, snippetId])
  @@index([snippetId])
}
model SnippetTag {
  id        String   @id @default(uuid())
  snippetId String
  tagId     String
  createdAt DateTime @default(now())

  snippet Snippet @relation(fields: [snippetId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([snippetId, tagId]) // prevenimos duplicação
  @@index([snippetId])
  @@index([tagId])
}
